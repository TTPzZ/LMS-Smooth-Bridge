PORT=3000
TRUST_PROXY=true

# Optional CORS whitelist (comma-separated). Leave empty to deny browser CORS by default.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Global request throttling for /api routes
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Firebase project API key used by verifyPassword and token refresh.
FIREBASE_API_KEY=

# Option A (recommended for long-term): store refresh token once.
LMS_REFRESH_TOKEN=

# Option B: login each time server starts, then auto refresh.
LMS_EMAIL=
LMS_PASSWORD=

# Optional fallback for quick test only (not recommended for daily use).
LMS_ID_TOKEN=

# Protect admin endpoints (/api/devices list, /api/notifier/status, /api/notifications/test)
ADMIN_API_SECRET=

# Hard limits for pagination/query load
MAX_ITEMS_PER_PAGE=100
MAX_MAX_PAGES=20
MAX_LOOKAHEAD_MINUTES=10080
MAX_REMINDER_SLOTS=200

# ------------------------------
# MongoDB
# ------------------------------
MONGO_URI=
MONGO_DB_NAME=lms_smooth_bridge

# ------------------------------
# Optional: Push notifier from backend (FCM)
# ------------------------------
ENABLE_PUSH_NOTIFIER=false
PUSH_NOTIFIER_INTERVAL_SECONDS=60
PUSH_LOOKAHEAD_MINUTES=15
PUSH_HISTORY_TTL_HOURS=72
CRON_SECRET=

# FCM legacy server key (from Firebase Cloud Messaging settings)
FCM_SERVER_KEY=
